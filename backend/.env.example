# ── Split Happens backend configuration ───────────────────────────────────────
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.

# --- Postgres ---
# LiteLLM and the FastAPI app use SEPARATE databases on the same server so their
# migration systems (Prisma vs. Alembic) never clobber each other.
POSTGRES_USER=splitt
# Can be created with: openssl rand -hex 32
POSTGRES_PASSWORD=change-me-postgres
# LiteLLM's database (Prisma-managed).
POSTGRES_DB=litellm
# The FastAPI app's database (Alembic-managed), created automatically on first run.
APP_DB=splitt_app
# NOTE: each service's DATABASE_URL is built automatically by docker-compose from
# the values above, so the password lives in exactly ONE place. Do not set
# DATABASE_URL here. (Only define it if you run the app OUTSIDE Docker, e.g. local pytest.)

# --- LiteLLM proxy ---
# Admin/master key for the LiteLLM proxy. Used by FastAPI to call LiteLLM's admin API.
# Create with: openssl rand -hex 32
LITELLM_MASTER_KEY=sk-change-me-master
# Base URL FastAPI uses to reach the LiteLLM proxy (host `litellm` = compose service).
LITELLM_BASE_URL=http://litellm:4000

# --- Upstream provider (OpenRouter, behind LiteLLM) ---
OPENROUTER_API_KEY=sk-or-change-me

# --- FastAPI app ---
# Secret used to derive the hash of opaque app tokens handed to clients.
# generate: openssl rand -hex 32
APP_TOKEN_SECRET=change-me
# Admin dashboard password.
ADMIN_PASSWORD=change-me-admin
# Secret used to sign admin session cookies.
SESSION_SECRET=change-me
# Default per-user spend budget in USD, applied on first registration.
DEFAULT_BUDGET_USD=5.00
